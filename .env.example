# =============================================================================
# Database
# =============================================================================

# asyncpg connection URL.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# The PostgreSQL server must have Apache AGE loaded (CREATE EXTENSION age).
DATABASE_URL=postgresql+asyncpg://sleuthgraph:changeme@localhost:5432/sleuthgraph

# =============================================================================
# Redis
# =============================================================================

# Redis connection URL used for session cache.
# Format without password: redis://localhost:6379/0
# Format with password:    redis://:PASSWORD@localhost:6379/0
REDIS_URL=redis://:changeme_local_only_redis@localhost:6379/0

# Redis URL for the arq background task queue.
# Defaults to REDIS_URL when unset — set separately only if the queue
# should run on a different Redis instance.
ARQ_REDIS_URL=redis://:changeme_local_only_redis@localhost:6379/0

# =============================================================================
# Auth
# =============================================================================

# JWT signing + credential encryption key. Required. Must be >= 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-string-min-32-chars

# Name of the session cookie.
AUTH_COOKIE_NAME=sleuthgraph_session

# Set to false for plain-HTTP local development. Must be true behind HTTPS.
AUTH_COOKIE_SECURE=true

# Session TTL in seconds. Default: 604800 (7 days).
AUTH_SESSION_LIFETIME_SECONDS=604800

# Enable the public POST /auth/register endpoint.
# Set to true during initial setup or self-hosted onboarding; disable after.
AUTH_ALLOW_SIGNUP=false

# Enable POST /auth/forgot-password and POST /auth/reset-password endpoints.
AUTH_ALLOW_PASSWORD_RESET=true

# Enable email-verification flow (POST /auth/request-verify-token and
# POST /auth/verify). Requires a working SMTP integration.
AUTH_ALLOW_EMAIL_VERIFY=false

# Base URL of the frontend application, used to build password-reset and
# verification links that are emailed to users.
# Example: https://app.sleuthgraph.io
AUTH_FRONTEND_BASE_URL=http://localhost:3000

# Bootstrap a superuser on first startup (idempotent after first run).
# Leave both unset to skip bootstrap. Remove these after the first deploy.
AUTH_ADMIN_EMAIL=
# Password for the bootstrap admin. Remove after first deploy.
AUTH_ADMIN_PASSWORD=

# =============================================================================
# S3 / Evidence Storage
# =============================================================================

# S3-compatible endpoint. For local dev this is MinIO.
# In production, use a publicly reachable URL so presigned blob URLs resolve
# from browsers (e.g. https://minio.yourdomain.com).
S3_ENDPOINT=http://localhost:9000

# S3 / MinIO access credentials.
S3_ACCESS_KEY=CHANGEME
# Rotate from default 'minioadmin' in production.
S3_SECRET_KEY=CHANGEME

# Bucket for evidence blobs. Must exist before the API starts
# (the minio-bootstrap Compose service creates it automatically).
S3_BUCKET=evidence

# S3 region. MinIO ignores this; set it to match your bucket region on AWS/R2.
S3_REGION=us-east-1

# Hard upload cap in bytes. Requests exceeding this are rejected with 413
# before the body is fully buffered. Default: 52428800 (50 MiB).
EVIDENCE_MAX_UPLOAD_BYTES=52428800

# =============================================================================
# OIDC  (optional — leave all unset to disable)
# =============================================================================

# Issuer URL of the OIDC provider.
# Example: https://accounts.google.com
#          https://login.microsoftonline.com/<tenant>/v2.0
OIDC_ISSUER=

# OAuth 2.0 client ID registered at the provider.
OIDC_CLIENT_ID=

# OAuth 2.0 client secret.
OIDC_CLIENT_SECRET=

# Absolute callback URL. Must match the redirect URI registered at the provider.
# REQUIRED when OIDC_ISSUER is set. Derivation from the incoming request is
# intentionally not supported (prevents host-header poisoning).
# Example: https://app.sleuthgraph.io/auth/oidc/callback
OIDC_REDIRECT_URL=

# Comma-separated list of OIDC scopes to request.
# Default: openid,email,profile
OIDC_SCOPES=openid,email,profile

# =============================================================================
# App
# =============================================================================

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# Anthropic API key. Optional — only required for AI-assisted features.
ANTHROPIC_API_KEY=

# Display name used in the OpenAPI title.
APP_NAME=Sleuthgraph API

# Enable debug mode. Never set to true in production.
# Setting false + AUTH_COOKIE_SECURE=false will cause the API to refuse startup.
DEBUG=false

# Expose the interactive OpenAPI docs (/docs, /redoc, /openapi.json).
# Default true preserves the OSS / dev experience. Set false in production
# so anonymous visitors can't enumerate the full API surface.
EXPOSE_API_DOCS=true

# =============================================================================
# Rate limiting
# =============================================================================

# Trust the CF-Connecting-IP / X-Forwarded-For headers when keying the
# per-IP rate limiter. Set to true ONLY when the API sits behind a proxy
# that strips client-supplied values (e.g. Cloudflare Tunnel). When the
# API is reachable directly, attackers can spoof these headers and bypass
# the per-IP buckets -- set false for self-hosted direct exposure.
TRUST_CLOUDFLARE_EDGE=true

# Per-endpoint rate-limit caps. Format follows the `limits` library
# grammar (e.g. "10/minute", "5/hour"). Tune per deployment risk
# appetite.
AUTH_LOGIN_IP_RATE=10/minute
AUTH_LOGIN_USERNAME_RATE=5/minute
AUTH_REGISTER_IP_RATE=5/minute
AUTH_OIDC_CALLBACK_IP_RATE=30/minute
AUTH_RESET_PASSWORD_IP_RATE=5/minute
AUTH_RESET_PASSWORD_TOKEN_RATE=5/hour
AUTH_FORGOT_PASSWORD_IP_RATE=5/minute
AUTH_FORGOT_PASSWORD_EMAIL_RATE=3/hour
