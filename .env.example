# --- Required ---
DATABASE_URL=postgresql+asyncpg://sleuthgraph:changeme@localhost:5432/sleuthgraph
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-to-a-random-64-char-string-min-32-chars

# --- Object storage (S3-compatible; MinIO in dev) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=evidence
S3_REGION=us-east-1

# --- Auth ---
AUTH_COOKIE_NAME=sleuthgraph_session
AUTH_COOKIE_SECURE=true
AUTH_SESSION_LIFETIME_SECONDS=604800
AUTH_ALLOW_SIGNUP=false
AUTH_ALLOW_PASSWORD_RESET=true
AUTH_ALLOW_EMAIL_VERIFY=false
AUTH_FRONTEND_BASE_URL=http://localhost:3000
# Bootstrap admin on first startup (optional)
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=

# --- OIDC (optional) ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Optional: explicit callback URL (derived from request if unset)
OIDC_REDIRECT_URL=
# Optional: CSV scopes (default: openid,email,profile)
OIDC_SCOPES=openid,email,profile

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Evidence uploads ---
EVIDENCE_MAX_UPLOAD_BYTES=52428800

# --- AI (optional — only required for Phase 10 features) ---
ANTHROPIC_API_KEY=

# --- App ---
APP_NAME=Sleuthgraph API
DEBUG=false
